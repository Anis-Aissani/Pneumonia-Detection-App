# =========================
# PYTHON CORE
# =========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Test and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# =========================
# VIRTUAL ENVIRONMENTS
# =========================
venv/
env/
ENV/
.venv/
.env_venv/

# =========================
# SECRETS & CONFIG (CRITICAL)
# =========================
.env
.env.local
*.env
secret_keys.py

# =========================
# DATA & MACHINE LEARNING
# =========================
# Ignore raw data and datasets (Add sample images manually if needed)
data/
datasets/
raw_data/
processed_data/
*.csv
*.dat
*.sqlite3
*.db

# Keep optional lightweight placeholders in ignored folders
!data/.gitkeep
!incoming_scans/.gitkeep
!heatmaps/.gitkeep

# Ignore heavy trained models (GitHub 100MB limit)
*.h5
*.hdf5
*.pkl
*.joblib
*.pt
*.pth
*.onnx
models/
saved_models/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# =========================
# WEB FRAMEWORKS (FLASK)
# =========================
instance/
.webassets-cache
flask_session/

# =========================
# IDE & OS FILES
# =========================
# VS Code
.vscode/
*.code-workspace

# macOS / Windows junk files
.DS_Store
Thumbs.db

# =========================
# LATEX / REPORT BUILD OUTPUTS
# =========================
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.glg
*.glo
*.gls
*.ist
*.lof
*.log
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb
*.xdv

# =========================
# PROJECT RUNTIME OUTPUTS
# =========================
# Generated heatmaps and scanner leftovers
heatmaps/heatmap_*.png
incoming_scans/processed/
incoming_scans/*.tmp

# Local backup/temporary files
*.bak
*.swp
*.swo

# =========================
# PERSONAL REVISION DOCUMENTS
# =========================
*.tex
rapport.tex
soutenance_beamer.tex
